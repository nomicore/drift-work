OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_PLANNING_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MAX_CLARIFICATION_TURNS=2
TOP_K_SEARCH=10
TOP_K_RERANK=5

# fal.ai — required for the "Fit it on my ride" AI image generation feature
# Get your key at https://fal.ai
FAL_KEY=

# Passphrase gate — protects the demo from public access
# Set any secret string; users must enter this to unlock the site
PASSPHRASE=your-secret-passphrase-here
# How many days the session cookie stays valid (default: 7)
SESSION_DAYS=7
